# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
ENV/

# Environment variables (보안: 절대 커밋 금지)
.env
.env.local
.env.production
*.secret
*.key

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Outputs (산출물은 Git에 포함하지 않되, 디렉터리 구조는 유지)
outputs/archive/*
outputs/draft/*
outputs/final/*
outputs/retrieval/*
outputs/runs/*
!outputs/**/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Testing
.coverage
htmlcov/
.pytest_cache/

# Evaluation outputs
outputs/evaluations/*
!outputs/evaluations/.gitkeep

# Distribution
*.tar.gz
*.whl

# Sensitive / internal
data/archive/
*.log
